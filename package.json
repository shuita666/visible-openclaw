{
  "name": "visible-openclaw",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "bridge": "node bridge/server.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "pm2 start ecosystem.config.cjs",
    "stop": "pm2 stop ecosystem.config.cjs",
    "restart": "pm2 restart ecosystem.config.cjs",
    "logs": "pm2 logs",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.mjs",
    "electron:build": "vite build && electron-builder"
  },
  "main": "electron/main.mjs",
  "build": {
    "appId": "com.openclaw.visible",
    "productName": "VisibleOpenclaw",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "bridge/**"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.5"
  }
}
